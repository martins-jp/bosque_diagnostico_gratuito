<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Escola Bosque — Diagnóstico de desenvolvimento</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@500;600;700;800&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --green-dark:#065E4A;
    --mint:#C2EED8;
    --lime:#EAFB8C;
    --purple:#A37FD6;
    --pink:#FF8AAE;
    --ink:#0D2620;
    --paper:#FBFAF6;
    --card:#FFFFFF;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{
    font-family:'Instrument Sans', sans-serif;
    background:var(--paper);
    color:var(--ink);
    min-height:100vh;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:24px 16px;
  }
  .app{
    width:100%;
    max-width:480px;
    background:var(--card);
    border-radius:24px;
    box-shadow:0 2px 4px rgba(13,38,32,0.04), 0 12px 32px rgba(13,38,32,0.08);
    overflow:hidden;
    position:relative;
  }
  .topbar{
    display:flex;
    align-items:center;
    gap:10px;
    padding:20px 24px 0 24px;
  }
  .brand{
    font-family:'Bricolage Grotesque', sans-serif;
    font-weight:700;
    font-size:14px;
    color:var(--green-dark);
    letter-spacing:0.02em;
  }
  .progress-wrap{
    padding:14px 24px 0 24px;
    display:none;
  }
  .progress-wrap.show{display:block;}
  .progress-track{
    height:6px;
    background:var(--mint);
    border-radius:100px;
    overflow:hidden;
  }
  .progress-fill{
    height:100%;
    background:var(--green-dark);
    border-radius:100px;
    transition:width 0.35s ease;
    width:0%;
  }
  .progress-label{
    font-size:12px;
    color:#5B6F69;
    margin-top:6px;
  }
  .screen{
    display:none;
    padding:28px 24px 32px 24px;
    animation:fadeIn 0.3s ease;
  }
  .screen.active{display:block;}
  @keyframes fadeIn{
    from{opacity:0; transform:translateY(6px);}
    to{opacity:1; transform:translateY(0);}
  }
  .eyebrow{
    font-size:12px;
    font-weight:600;
    color:var(--purple);
    text-transform:uppercase;
    letter-spacing:0.06em;
    margin-bottom:10px;
  }
  h1{
    font-family:'Bricolage Grotesque', sans-serif;
    font-weight:700;
    font-size:28px;
    line-height:1.15;
    color:var(--green-dark);
    margin-bottom:12px;
  }
  h2{
    font-family:'Bricolage Grotesque', sans-serif;
    font-weight:600;
    font-size:20px;
    line-height:1.25;
    color:var(--ink);
    margin-bottom:4px;
  }
  .sub{
    font-size:15px;
    color:#475953;
    line-height:1.5;
    margin-bottom:24px;
  }
  .time-pill{
    display:inline-flex;
    align-items:center;
    gap:6px;
    background:var(--mint);
    color:var(--green-dark);
    font-size:13px;
    font-weight:500;
    padding:6px 14px;
    border-radius:100px;
    margin-bottom:22px;
  }
  .pillars-preview{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:10px;
    margin-bottom:28px;
  }
  .pillar-chip{
    background:var(--paper);
    border:1px solid #E7E3D6;
    border-radius:12px;
    padding:10px 12px;
    font-size:13px;
    font-weight:500;
    color:var(--ink);
  }
  button.cta{
    width:100%;
    background:var(--green-dark);
    color:#fff;
    border:none;
    font-family:'Instrument Sans', sans-serif;
    font-weight:600;
    font-size:16px;
    padding:16px;
    border-radius:14px;
    cursor:pointer;
    transition:transform 0.15s ease, background 0.15s ease;
  }
  button.cta:hover{background:#054d3d;}
  button.cta:active{transform:scale(0.98);}
  .option{
    display:flex;
    align-items:center;
    gap:12px;
    border:1.5px solid #E7E3D6;
    border-radius:14px;
    padding:16px;
    margin-bottom:10px;
    cursor:pointer;
    font-size:15px;
    font-weight:500;
    transition:border-color 0.15s ease, background 0.15s ease;
  }
  .option:hover{border-color:var(--purple); background:#FAF8FF;}
  .option .dot{
    width:18px; height:18px;
    border-radius:50%;
    border:2px solid #C9C4B3;
    flex-shrink:0;
  }
  .option.selected{border-color:var(--green-dark); background:var(--mint);}
  .option.selected .dot{border-color:var(--green-dark); background:var(--green-dark);}
  .pillar-tag{
    font-size:12px;
    font-weight:600;
    color:#8A7DC2;
    background:#F1EDFB;
    display:inline-block;
    padding:4px 10px;
    border-radius:100px;
    margin-bottom:14px;
  }
  .nav-row{
    display:flex;
    gap:10px;
    margin-top:8px;
  }
  .btn-back{
    background:none;
    border:1.5px solid #E7E3D6;
    color:#5B6F69;
    font-family:'Instrument Sans', sans-serif;
    font-weight:500;
    font-size:14px;
    padding:12px 16px;
    border-radius:12px;
    cursor:pointer;
  }
  input[type=text], input[type=email], input[type=tel]{
    width:100%;
    font-family:'Instrument Sans', sans-serif;
    font-size:15px;
    padding:14px 16px;
    border:1.5px solid #E7E3D6;
    border-radius:12px;
    margin-bottom:12px;
    background:var(--paper);
  }
  input:focus{outline:none; border-color:var(--green-dark);}
  .field-label{
    font-size:13px;
    font-weight:500;
    color:#5B6F69;
    margin-bottom:6px;
    display:block;
  }
  .field-block{margin-bottom:14px;}
  .privacy-note{
    font-size:12px;
    color:#8A9A94;
    margin:10px 0 18px 0;
    line-height:1.5;
  }
  .result-badge{
    display:inline-block;
    font-family:'Bricolage Grotesque', sans-serif;
    font-weight:700;
    font-size:14px;
    padding:8px 16px;
    border-radius:100px;
    margin-bottom:18px;
  }
  .badge-alto{background:var(--lime); color:#3A4A0E;}
  .badge-medio{background:var(--mint); color:var(--green-dark);}
  .badge-baixo{background:#FDE3EA; color:#8A2E45;}
  .result-text{
    font-size:15px;
    line-height:1.6;
    color:#3A4A44;
    margin-bottom:24px;
  }
  .bars{margin-bottom:24px;}
  .bar-row{margin-bottom:14px;}
  .bar-label{
    display:flex;
    justify-content:space-between;
    font-size:13px;
    font-weight:500;
    color:var(--ink);
    margin-bottom:6px;
  }
  .bar-track{
    height:8px;
    background:#EFEBDD;
    border-radius:100px;
    overflow:hidden;
  }
  .bar-fill{
    height:100%;
    border-radius:100px;
    background:var(--purple);
    transition:width 0.6s ease;
  }
  .manifest-line{
    font-family:'Bricolage Grotesque', sans-serif;
    font-weight:600;
    font-size:15px;
    color:var(--green-dark);
    border-left:3px solid var(--pink);
    padding-left:14px;
    margin-bottom:24px;
  }
</style>
</head>
<body>

<div class="app">

  <div class="topbar">
    <span class="brand">ESCOLA BOSQUE</span>
  </div>

  <div class="progress-wrap" id="progressWrap">
    <div class="progress-track"><div class="progress-fill" id="progressFill"></div></div>
    <div class="progress-label" id="progressLabel"></div>
  </div>

  <!-- SCREEN 0: HOOK -->
  <div class="screen active" id="screen-hook">
    <div class="eyebrow">Diagnóstico gratuito</div>
    <h1>Seu filho(a) está evoluindo ou só passando de ano?</h1>
    <p class="sub">Responda algumas perguntas simples e receba um raio-x do desenvolvimento acadêmico, socioemocional, de autonomia e de engajamento do seu filho(a) — com uma classificação clara ao final.</p>
    <div class="time-pill">⏱ Leva 2 minutos</div>
    <div class="pillars-preview">
      <div class="pillar-chip">Acadêmico</div>
      <div class="pillar-chip">Socioemocional</div>
      <div class="pillar-chip">Autonomia</div>
      <div class="pillar-chip">Engajamento</div>
    </div>
    <button class="cta" onclick="goTo('grade')">Clique aqui e descubra</button>
  </div>

  <!-- SCREEN 1: FASE ESCOLAR -->
  <div class="screen" id="screen-grade">
    <h2>Qual a fase escolar do seu filho(a)?</h2>
    <p class="sub">Isso ajuda a personalizar o seu resultado.</p>
    <div class="option" data-group="grade" data-value="infantil" onclick="selectOption(this)">
      <div class="dot"></div> Educação infantil
    </div>
    <div class="option" data-group="grade" data-value="fund1" onclick="selectOption(this)">
      <div class="dot"></div> Fundamental I
    </div>
    <div class="option" data-group="grade" data-value="fund2" onclick="selectOption(this)">
      <div class="dot"></div> Fundamental II
    </div>
  </div>

  <!-- SCREENS 2-9: PERGUNTAS (geradas via JS) -->
  <div class="screen" id="screen-questions"></div>

  <!-- SCREEN 10: CAPTURA -->
  <div class="screen" id="screen-capture">
    <div class="eyebrow">Quase lá</div>
    <h2>Situação atual mapeada</h2>
    <p class="sub">Para onde enviamos o resultado completo?</p>
    <div class="field-block">
      <label class="field-label">Nome do responsável</label>
      <input type="text" id="inputNome" placeholder="Seu nome">
    </div>
    <div class="field-block">
      <label class="field-label">E-mail</label>
      <input type="email" id="inputEmail" placeholder="voce@email.com">
    </div>
    <div class="field-block">
      <label class="field-label">WhatsApp</label>
      <input type="tel" id="inputWhats" placeholder="(11) 90000-0000">
    </div>
    <p class="privacy-note">Usamos esses dados apenas para enviar seu resultado e falar sobre a Escola Bosque. Sem spam.</p>
    <button class="cta" onclick="showResult()">Ver meu resultado</button>
  </div>

  <!-- SCREEN 11: RESULTADO -->
  <div class="screen" id="screen-result">
    <div class="eyebrow">Seu resultado</div>
    <div id="resultBadge" class="result-badge">—</div>
    <p class="result-text" id="resultText"></p>
    <div class="bars" id="resultBars"></div>
    <div class="manifest-line">Preparo acadêmico de excelência para as provas que ele(a) vai enfrentar — e para a vida também.</div>
    <button class="cta" onclick="alert('Em um material real, este botão abriria o agendamento de visita.')">Saiba como a Escola Bosque pode ajudar no desenvolvimento do seu filho(a)</button>
  </div>

</div>

<script>
  const PILLARS = [
    { key:'academico', label:'Acadêmico' },
    { key:'socioemocional', label:'Socioemocional' },
    { key:'autonomia', label:'Autonomia' },
    { key:'engajamento', label:'Engajamento' }
  ];

  const QUESTIONS = [
    { pillar:'academico', text:'Quando ele(a) não consegue fazer algo de primeira, o que costuma acontecer?',
      options:[
        { label:'Ele(a) tenta de novo por conta própria até conseguir', score:5 },
        { label:'Tenta, mas precisa de incentivo para continuar', score:3 },
        { label:'Desiste rápido ou evita tentar de novo', score:1 }
      ]},
    { pillar:'academico', text:'Ele(a) consegue mostrar ou contar o que aprendeu recentemente (um desenho, uma tarefa, uma história, uma ideia nova)?',
      options:[
        { label:'Sim, com facilidade e interesse', score:5 },
        { label:'Só quando alguém pergunta diretamente', score:3 },
        { label:'Tem dificuldade de expressar o que aprendeu', score:1 }
      ]},
    { pillar:'socioemocional', text:'Como ele(a) lida quando algo não sai como esperado?',
      options:[
        { label:'Se frustra, mas consegue se acalmar e seguir sozinho(a)', score:5 },
        { label:'Precisa de ajuda para se acalmar, mas consegue', score:3 },
        { label:'Tem dificuldade grande de lidar com frustração', score:1 }
      ]},
    { pillar:'socioemocional', text:'Como é a relação dele(a) com outras crianças?',
      options:[
        { label:'Interage bem, faz amizades e resolve pequenos conflitos', score:5 },
        { label:'Interage, mas evita ou sofre com conflitos', score:3 },
        { label:'Prefere ficar sozinho(a) ou tem dificuldade de se relacionar', score:1 }
      ]},
    { pillar:'autonomia', text:'Ele(a) cuida de tarefas simples do dia a dia sozinho(a) (organizar brinquedos/mochila, se vestir, seguir a rotina), de acordo com a idade?',
      options:[
        { label:'Sim, sem que ninguém precise lembrar', score:5 },
        { label:'Só se alguém lembrar ou ajudar', score:3 },
        { label:'Depende totalmente de um adulto para isso', score:1 }
      ]},
    { pillar:'autonomia', text:'Quando surge um probleminha simples, o que ele(a) faz primeiro?',
      options:[
        { label:'Tenta resolver sozinho(a) antes de pedir ajuda', score:5 },
        { label:'Pede ajuda logo, mas participa da solução', score:3 },
        { label:'Espera que um adulto resolva por ele(a)', score:1 }
      ]},
    { pillar:'engajamento', text:'Como ele(a) fala sobre a escola em casa?',
      options:[
        { label:'Comenta espontaneamente o que viveu ou aprendeu no dia', score:5 },
        { label:'Só responde se alguém perguntar', score:3 },
        { label:'Evita o assunto ou demonstra desinteresse', score:1 }
      ]},
    { pillar:'engajamento', text:'Ele(a) faz perguntas ou quer entender o porquê das coisas, além do que é pedido?',
      options:[
        { label:'Sim, com frequência e curiosidade própria', score:5 },
        { label:'Às vezes, quando algo chama atenção', score:3 },
        { label:'Raramente demonstra esse tipo de interesse', score:1 }
      ]}
  ];

  let currentQuestionIndex = 0;
  let gradeAnswer = null;
  const answers = new Array(QUESTIONS.length).fill(null);

  const TOTAL_STEPS = 1 + QUESTIONS.length; // grade + questions, used for progress bar

  function goTo(step){
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    if(step === 'grade'){
      document.getElementById('screen-grade').classList.add('active');
      updateProgress(1);
    }
  }

  function selectOption(el){
    const group = el.dataset.group;
    document.querySelectorAll(`.option[data-group="${group}"]`).forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');

    if(group === 'grade'){
      gradeAnswer = el.dataset.value;
      setTimeout(() => { renderQuestion(0); }, 200);
    }
  }

  function renderQuestion(index){
    currentQuestionIndex = index;
    const q = QUESTIONS[index];
    const pillarLabel = PILLARS.find(p => p.key === q.pillar).label;

    const container = document.getElementById('screen-questions');
    container.innerHTML = `
      <div class="pillar-tag">${pillarLabel}</div>
      <h2>${q.text}</h2>
      <div style="margin-top:18px;">
        ${q.options.map((opt, i) => `
          <div class="option" data-group="q${index}" data-value="${i}" onclick="answerQuestion(${index}, ${i}, this)">
            <div class="dot"></div> ${opt.label}
          </div>
        `).join('')}
      </div>
      <div class="nav-row">
        ${index > 0 ? `<button class="btn-back" onclick="goBack()">Voltar</button>` : ''}
      </div>
    `;

    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    document.getElementById('screen-questions').classList.add('active');
    updateProgress(2 + index);

    // Restore previous selection if navigating back
    if(answers[index] !== null){
      const prevSelected = container.querySelector(`.option[data-value="${answers[index]}"]`);
      if(prevSelected) prevSelected.classList.add('selected');
    }
  }

  function answerQuestion(qIndex, optIndex, el){
    document.querySelectorAll(`.option[data-group="q${qIndex}"]`).forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
    answers[qIndex] = optIndex;

    setTimeout(() => {
      if(qIndex < QUESTIONS.length - 1){
        renderQuestion(qIndex + 1);
      } else {
        goToCapture();
      }
    }, 250);
  }

  function goBack(){
    if(currentQuestionIndex > 0){
      renderQuestion(currentQuestionIndex - 1);
    } else {
      document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
      document.getElementById('screen-grade').classList.add('active');
      updateProgress(1);
    }
  }

  function goToCapture(){
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    document.getElementById('screen-capture').classList.add('active');
    updateProgress(TOTAL_STEPS);
  }

  function updateProgress(stepNumber){
    const wrap = document.getElementById('progressWrap');
    const fill = document.getElementById('progressFill');
    const label = document.getElementById('progressLabel');
    wrap.classList.add('show');
    const pct = Math.round((stepNumber / TOTAL_STEPS) * 100);
    fill.style.width = pct + '%';
    label.textContent = `Etapa ${stepNumber} de ${TOTAL_STEPS}`;
  }

  function showResult(){
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    document.getElementById('screen-result').classList.add('active');
    document.getElementById('progressWrap').classList.remove('show');

    // Calculate per-pillar and total scores
    const pillarScores = {};
    PILLARS.forEach(p => pillarScores[p.key] = { total:0, max:0 });

    QUESTIONS.forEach((q, i) => {
      const optIndex = answers[i];
      const score = optIndex !== null ? q.options[optIndex].score : 0;
      pillarScores[q.pillar].total += score;
      pillarScores[q.pillar].max += 5;
    });

    let grandTotal = 0;
    QUESTIONS.forEach((q, i) => {
      const optIndex = answers[i];
      grandTotal += optIndex !== null ? q.options[optIndex].score : 0;
    });

    // Classification bands: 8-40 total -> baixo/medio/alto
    let level, badgeClass, text;
    if(grandTotal <= 20){
      level = 'Desenvolvimento baixo';
      badgeClass = 'badge-baixo';
      text = 'Existem sinais importantes que merecem atenção próxima. Isso não é motivo de alarme — é um convite para olhar de perto o que pode estar travando o desenvolvimento do seu filho(a) e agir agora, enquanto o ajuste é mais simples.';
    } else if(grandTotal <= 30){
      level = 'Desenvolvimento médio';
      badgeClass = 'badge-medio';
      text = 'Seu filho(a) tem uma base sólida, com pontos fortes claros e outros que ainda estão em construção. É o momento ideal para reforçar o que já funciona e dar atenção extra ao que está mais atrás.';
    } else {
      level = 'Desenvolvimento alto';
      badgeClass = 'badge-alto';
      text = 'Seu filho(a) mostra sinais consistentes de evolução em várias frentes — não só academicamente, mas também emocionalmente e na forma como se relaciona com o mundo. Vale manter esse ambiente de estímulo.';
    }

    document.getElementById('resultBadge').textContent = level;
    document.getElementById('resultBadge').className = 'result-badge ' + badgeClass;
    document.getElementById('resultText').textContent = text;

    const barsContainer = document.getElementById('resultBars');
    barsContainer.innerHTML = PILLARS.map(p => {
      const s = pillarScores[p.key];
      const pct = Math.round((s.total / s.max) * 100);
      return `
        <div class="bar-row">
          <div class="bar-label"><span>${p.label}</span><span>${pct}%</span></div>
          <div class="bar-track"><div class="bar-fill" style="width:${pct}%"></div></div>
        </div>
      `;
    }).join('');
  }
</script>

</body>
</html>
